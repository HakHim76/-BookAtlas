<h1 class="page-title">Search Books</h1>
<form action="/books" method="GET" class="search-form search-form-compact">

  <div class="form-group">
    <label for="title">Name</label>
    <input
      type="text"
      name="title"
      id="title"
      value="<%= searchOptions.title %>"
    />
  </div>

  <div class="form-group">
    <label for="publishedBefore">Published Before</label>
    <input
      type="date"
      name="publishedBefore"
      id="publishedBefore"
      value="<%= searchOptions.publishedBefore %>"
    />
  </div>

  <div class="form-group">
    <label for="publishedAfter">Published After</label>
    <input
      type="date"
      name="publishedAfter"
      id="publishedAfter"
      value="<%= searchOptions.publishedAfter %>"
    />
  </div>

<button class="btn-primary btn-search" type="submit">Search</button>

</form>


<div class="books-showcase">

  <% books.forEach(book => { %>

    <a href="/books/<%= book.id %>" class="book-card">
      <img
        src="<%= book.coverImagePath %>"
        class="book-cover"
      >
    </a>

  <% }) %>

</div>