<h1 class="page-title">Search Authors</h1>

<form action="/authors" method="GET" class="search-form author-search-form">
  <div class="form-group">
    <label for="name">Name</label>
    <input
      type="text"
      id="name"
      name="name"
      value="<%= searchOptions.name %>"
    />
  </div>

  <button type="submit" class="btn-primary">Search</button>
</form>

<div class="author-list">
  <% authors.forEach(author => { %>
    <div class="author-card">
      <div class="author-card-name"><%= author.name %></div>

      <div class="author-card-actions">
        <a href="/authors/<%= author.id %>" class="btn-secondary">View</a>
        <a href="/authors/<%= author.id %>/edit" class="btn-secondary">Edit</a>

        <%- include("../partials/delete_Form.ejs", { url: `/authors/${author.id}` }) %>
      </div>
    </div>
  <% }) %>
</div>